---
import '@/styles/globals.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import logoMark from '@/assets/logo/Bitten_Cookie-removebg-preview.png';
import cookiesBanner from '@/assets/cookies/Cookies-banner.webp';

const siteUrl = 'https://www.pinckmax.com.br';
const ogImageUrl = new URL(cookiesBanner.src, siteUrl).toString();
---

<!doctype html>
<html lang="pt-BR" class="h-full w-full lenis lenis-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta id="color-scheme-meta" name="color-scheme" content="light" />
		<link rel="icon" type="image/webp" href={logoMark.src} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
			/>
		</noscript>
		<meta name="generator" content={Astro.generator} />
		<title>Pinckmax Bakery – Confeitaria Artesanal</title>
		<meta
			name="description"
			content="Confeitaria artesanal da Pinckmax: cookies, bolos e doces caseiros feitos com carinho. Encomendas e novidades toda semana."
		/>
		<link rel="canonical" href={siteUrl} />
		<meta property="og:site_name" content="Pinckmax Bakery" />
		<meta property="og:title" content="Pinckmax Bakery – Confeitaria Artesanal" />
		<meta
			property="og:description"
			content="Confeitaria artesanal da Pinckmax: cookies, bolos e doces caseiros feitos com carinho. Encomendas e novidades toda semana."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="pt_BR" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content="Pinckmax Bakery" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Pinckmax Bakery – Confeitaria Artesanal" />
		<meta
			name="twitter:description"
			content="Confeitaria artesanal da Pinckmax: cookies, bolos e doces caseiros feitos com carinho. Encomendas e novidades toda semana."
		/>
		<meta name="twitter:image" content={ogImageUrl} />
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
			const meta = document.getElementById('color-scheme-meta');
			if (meta) meta.setAttribute('content', isDark ? 'dark' : 'light');
		</script>
	</head>
	<body class="m-0 min-h-full w-full overflow-x-hidden">
		<slot />
		<SpeedInsights />
		<Analytics />
		<script>
			import { initSmoothScroll, initScrollAnimations } from '@/scripts/smoothScroll';
			document.addEventListener('DOMContentLoaded', () => {
				initSmoothScroll();
				initScrollAnimations();
				setTimeout(initScrollAnimations, 150);
			});
		</script>
	</body>
</html>
