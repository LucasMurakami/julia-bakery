---
import FlavorMarquee from '@/components/Home/FlavorMarquee.astro';
---

<section id="flavors" class="mt-16 md:mt-20">
	<div class="max-w-xl">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">
			Barra de sabores animada
		</p>
		<h2 class="mt-3 text-2xl font-semibold md:text-3xl">
			Movimento, textura e calor — na medida certa para um estúdio solo.
		</h2>
		<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))] md:text-base">
			Inspirado em storytelling de padarias premium, mas pensado para um negócio de
			uma pessoa só.
		</p>
	</div>
	<FlavorMarquee />
	<div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
		<div class="relative overflow-hidden rounded-2xl bg-white/85 dark:bg-neutral-800/85 p-5 shadow-lg">
			<span class="inline-flex rounded-xl bg-white dark:bg-neutral-700 p-2 text-xl shadow">🍓</span>
			<h3 class="mt-4 text-lg font-semibold">Framboesa & Rosa</h3>
			<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
				Ondas de geleia + cobertura floral para lançamentos.
			</p>
			<div class="pointer-events-none absolute -inset-x-6 -bottom-16 h-28 bg-[radial-gradient(circle,rgba(255,207,178,0.9),transparent_70%)] dark:opacity-30 animate-[sweep_6s_linear_infinite]"></div>
		</div>
		<div class="relative overflow-hidden rounded-2xl bg-white/85 dark:bg-neutral-800/85 p-5 shadow-lg">
			<span class="inline-flex rounded-xl bg-white dark:bg-neutral-700 p-2 text-xl shadow">🍯</span>
			<h3 class="mt-4 text-lg font-semibold">Aveia & Mel</h3>
			<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
				Massa macia, aveia tostada e conforto dourado.
			</p>
			<div class="pointer-events-none absolute -inset-x-6 -bottom-16 h-28 bg-[radial-gradient(circle,rgba(255,207,178,0.9),transparent_70%)] dark:opacity-30 animate-[sweep_6s_linear_infinite]"></div>
		</div>
		<div class="relative overflow-hidden rounded-2xl bg-white/85 dark:bg-neutral-800/85 p-5 shadow-lg">
			<span class="inline-flex rounded-xl bg-white dark:bg-neutral-700 p-2 text-xl shadow">🍫</span>
			<h3 class="mt-4 text-lg font-semibold">Cacau Salgado</h3>
			<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
				Ganache aveludada que fotografa lindamente.
			</p>
			<div class="pointer-events-none absolute -inset-x-6 -bottom-16 h-28 bg-[radial-gradient(circle,rgba(255,207,178,0.9),transparent_70%)] dark:opacity-30 animate-[sweep_6s_linear_infinite]"></div>
		</div>
		<div class="relative overflow-hidden rounded-2xl bg-white/85 dark:bg-neutral-800/85 p-5 shadow-lg">
			<span class="inline-flex rounded-xl bg-white dark:bg-neutral-700 p-2 text-xl shadow">🍋</span>
			<h3 class="mt-4 text-lg font-semibold">Limão Nuvem</h3>
			<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
				Curd cítrico, creme leve e raspas delicadas.
			</p>
			<div class="pointer-events-none absolute -inset-x-6 -bottom-16 h-28 bg-[radial-gradient(circle,rgba(255,207,178,0.9),transparent_70%)] dark:opacity-30 animate-[sweep_6s_linear_infinite]"></div>
		</div>
	</div>
</section>
